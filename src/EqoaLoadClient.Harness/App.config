<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    eqoa-loadclient harness config. Edit these and press F5 in Visual Studio
    (or run "dotnet run"). Any key can also be overridden on the command line
    as key=value tokens, e.g.  BotCount=200 SpawnMode=Clustered RampMs=150000

    Defaults below are the T1 realistic-baseline tier. Tier ladder (edit BotCount /
    RampMs / TickThreads / DurationSec per tier; add hubs at higher tiers):
      T1  BotCount=100 RampMs=90000  TickThreads=1 DurationSec=420
      T2  BotCount=200 RampMs=150000 TickThreads=2 DurationSec=480
      T3  BotCount=300 RampMs=220000 TickThreads=4 DurationSec=560   (add a 4th/5th hub)
      T4  BotCount=500 RampMs=360000 TickThreads=6 DurationSec=700   (add a 5th/6th hub)
  -->
  <appSettings>
    <!-- ===== Server ===== -->
    <add key="ServerIp"    value="192.168.1.112" />
    <add key="ServerPort"  value="10070" />
    <add key="JoinOpcode"  value="0BB0" />        <!-- hex u16 GameOpcode (emu: LoadBotJoin) -->

    <!-- ===== Fleet size ===== -->
    <add key="BotCount"    value="100" />         <!-- number of bots to run concurrently -->

    <!-- ===== Where they land ===== -->
    <add key="WorldID"     value="0" />           <!-- world (not a grid zone): 0=Tunaria 1=Rathe 2=Odus 3=LavaStorm 4=PlaneOfSky 5=Secrets -->
    <add key="SpawnMode"   value="Clustered" />   <!-- Clustered = weighted hubs + in-hub wander (realistic; bounded cold zones); Random = each bot at a random valid world point (max spread); Fixed = every bot at Spawn(X,Y,Z) -->
    <add key="SpawnX"      value="5950" />        <!-- Fixed mode only: middle of the Qeynos cell; must be a valid land cell -->
    <add key="SpawnY"      value="50" />          <!-- Y is not used for the zone lookup; keep ~[0,250] -->
    <add key="SpawnZ"      value="17950" />

    <!-- ===== Hub clustering (Clustered mode) ===== -->
    <!-- "x,z,weight; ..." verified-valid world-0 anchors. Weight is relative concentration.
         Add hubs for higher tiers, e.g. Highpass 17054,15606 / Serpent Hills 16059,22705 /
         Aviak 9725,20525 / Stone Watchers 19064,31747, to keep the densest cell realistic. -->
    <add key="Hubs"        value="5950,17950,45; 15315,11715,30; 15750,20373,25" />
    <add key="HubJitter"   value="350" />         <!-- +/- spawn scatter around a hub anchor (clamped to HubWander) -->
    <add key="HubWander"   value="400" />         <!-- +/- wander box half-extent; keep &lt; 1000 so bots stay in the hub's cell -->

    <!-- ===== Movement ===== -->
    <add key="RoamSpeed"    value="30" />         <!-- units/sec; ~100 crosses a 2000-unit cell in ~20s -->
    <add key="IntervalMs"   value="100" />        <!-- movement cadence (server default 100) -->
    <add key="ClusterId"    value="0" />          <!-- wire Cluster field sent to the emu (not spatial) -->

    <!-- ===== Ramp + threading (realism dials) ===== -->
    <add key="RampMs"       value="90000" />      <!-- staggered join window; bot i joins at i*(RampMs/N). 0 = all at once (thundering herd) -->
    <add key="TickThreads"  value="1" />          <!-- shard the tick loop across N threads so the harness is not the bottleneck at high N (300+ => 4-6) -->

    <!-- ===== Diagnostics ===== -->
    <add key="TagBot"         value="0" />        <!-- print this bot's position every 10s (proof of movement) -->
    <add key="ZoneLoadMargin" value="100" />      <!-- print when any bot comes within N units of a cell border (server loads a zone at ~100u); 0 = off -->

    <!-- ===== Run ===== -->
    <add key="DurationSec"  value="420" />        <!-- total run seconds (>= RampMs/1000 + hold). 0 = until Ctrl-C -->
    <add key="Seed"         value="1" />          <!-- RNG seed for reproducible spawns/assignment/wander -->

    <!-- ===== Session id bases (each bot gets Base + index; keep bots distinct) ===== -->
    <add key="BaseInstanceId"  value="65536" />   <!-- 0x00010000 -->
    <add key="BaseSrcEndpoint" value="258" />     <!-- 0x0102 -->
  </appSettings>
</configuration>
