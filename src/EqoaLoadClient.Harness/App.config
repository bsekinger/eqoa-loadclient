<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    eqoa-loadclient harness config. Edit these and press F5 in Visual Studio
    (or run "dotnet run"). Any key can also be overridden on the command line
    as key=value tokens, e.g.  BotCount=10 SpawnMode=Random
  -->
  <appSettings>
    <!-- ===== Server ===== -->
    <add key="ServerIp"    value="192.168.1.112" />
    <add key="ServerPort"  value="10070" />
    <add key="JoinOpcode"  value="0BB0" />        <!-- hex u16 GameOpcode (emu: LoadBotJoin) -->

    <!-- ===== Fleet size ===== -->
    <add key="BotCount"    value="1" />           <!-- number of bots to run concurrently -->

    <!-- ===== Where they land ===== -->
    <add key="WorldID"     value="0" />           <!-- world (not a grid zone): 0=Tunaria 1=Rathe 2=Odus 3=LavaStorm 4=PlaneOfSky 5=Secrets -->
    <add key="SpawnMode"   value="Fixed" />       <!-- Fixed = every bot at Spawn(X,Y,Z);  Random = each bot randomized within +/- SpawnRange -->
    <add key="SpawnX"      value="5000" />        <!-- middle of the Qeynos cell (_zones[2][8]) -->
    <add key="SpawnY"      value="50" />          <!-- Y is not used for the zone lookup; keep ~[0,250] -->
    <add key="SpawnZ"      value="17000" />
    <add key="SpawnRangeX" value="3000" />        <!-- Random mode only: bot X in [SpawnX-Range .. SpawnX+Range] -->
    <add key="SpawnRangeZ" value="3000" />        <!-- Random mode only: bot Z in [SpawnZ-Range .. SpawnZ+Range] -->
    <!-- IMPORTANT: spawn AND the wander box must stay inside all-land cells (2000-unit grid).
         Safe Tunaria rectangles: block A X4000-12000/Z4000-22000, block B X12000-20000/Z4000-32000.
         Keep SpawnX/Z +/- (SpawnRange + WanderRadius) inside one of those. -->

    <!-- ===== Movement ===== -->
    <add key="WanderRadius" value="1000" />        <!-- per-bot wander box half-size in X/Z -->
    <add key="IntervalMs"   value="100" />        <!-- movement cadence (server default 100) -->
    <add key="ClusterId"    value="0" />          <!-- bots with the same ClusterId concentrate into one proximity hotspot -->

    <!-- ===== Run ===== -->
    <add key="DurationSec"  value="0" />          <!-- 0 = run until Ctrl-C; >0 = self-terminate after N seconds -->
    <add key="Seed"         value="1" />          <!-- RNG seed for reproducible random spawns/wander -->

    <!-- ===== Session id bases (each bot gets Base + index; keep bots distinct) ===== -->
    <add key="BaseInstanceId"  value="65536" />   <!-- 0x00010000 -->
    <add key="BaseSrcEndpoint" value="258" />     <!-- 0x0102 -->
  </appSettings>
</configuration>
